{
  "name": "grok-build-gui",
  "version": "0.1.1",
  "private": true,
  "description": "A function-first Windows desktop client for Grok Build CLI",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "build": "npm run typecheck && electron-vite build",
    "package": "npm run test && npm run build && electron-builder --win nsis",
    "lint": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@fontsource-variable/ibm-plex-sans": "^5.2.7",
    "@fontsource-variable/newsreader": "^5.2.8",
    "electron-store": "^10.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "react-virtuoso": "^4.12.3",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "tw.jackie.grokbuildgui",
    "productName": "Grok Build GUI",
    "asar": true,
    "files": [
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "output": "outputs/installer"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
